# App
APP_ENV=development
DATABASE_PATH=data/paper_quant.sqlite3
DEFAULT_SYMBOLS=AAPL,MSFT,SPY
HOST_PORT=8000

# Alpaca paper trading credentials.
# Never commit real secrets. Use Alpaca's paper endpoint unless you intentionally
# extend the app and risk controls for live trading.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# Dashboard/API authentication.
# Keep AUTH_ENABLED=true on shared hosts and production deployments.
AUTH_ENABLED=true
ADMIN_USERNAME=admin
# Prefer ADMIN_PASSWORD_HASH. Generate one locally with:
# PYTHONPATH=src python -c "from trading_app.auth import hash_password; import getpass; print(hash_password(getpass.getpass()))"
ADMIN_PASSWORD_HASH=
# ADMIN_PASSWORD is accepted for local/dev convenience if no hash is set.
ADMIN_PASSWORD=
# Required when AUTH_ENABLED=true and APP_ENV=production.
SESSION_SECRET=
SESSION_COOKIE_NAME=paper_quant_session
SESSION_MAX_AGE_SECONDS=86400

# Safety defaults. Keep both true for the scaffold.
DRY_RUN=true
PAPER_TRADING_ONLY=true
MAX_ORDER_NOTIONAL=1000
MAX_POSITION_NOTIONAL=5000
MAX_DAILY_ORDERS=10
MAX_STRATEGY_DRAWDOWN=0.25
MAX_PROBABILITY_OF_RUIN=0.05
